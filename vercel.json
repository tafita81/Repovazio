{
  "buildCommand": "next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": [
    "iad1"
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/hub.html",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 6 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/galeria-videos.html",
      "destination": "/api/galeria-videos"
    }
  ]
}
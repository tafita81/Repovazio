{
  "framework": "nextjs",
  "crons": [
    { "path": "/api/cerebro", "schedule": "*/15 * * * *" },
    { "path": "/api/cerebro/aprender", "schedule": "0 * * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
